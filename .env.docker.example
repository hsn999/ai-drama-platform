# Docker Compose 环境变量示例
# 用法: copy .env.docker.example .env

# ===== 应用 =====
APP_ENV=production
APP_PORT=8000
FRONTEND_PORT=80
SECRET_KEY=change-me-to-random-string

# ===== 数据库 =====
# MVP（默认 SQLite，无需 postgres 容器）
DATABASE_URL=sqlite+aiosqlite:////app/storage/ai_drama.db

# V1.1+ 使用 PostgreSQL（需 --profile full）
# DATABASE_URL=postgresql+asyncpg://drama:drama123@postgres:5432/ai_drama
# POSTGRES_USER=drama
# POSTGRES_PASSWORD=drama123
# POSTGRES_DB=ai_drama
# POSTGRES_PORT=5432

# ===== Redis =====
REDIS_PORT=6379

# ===== Ollama（--profile gpu）=====
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3:8b

# ===== ComfyUI（--profile gpu）=====
COMFYUI_PORT=8188
# 模型目录挂载到宿主机（需提前下载模型，见 doc/组件安装与配置指南.md 9.4 节）
COMFYUI_MODELS_DIR=./data/comfyui/models
COMFYUI_CUSTOM_NODES_DIR=./data/comfyui/custom_nodes
COMFYUI_INPUT_DIR=./data/comfyui/input

# ===== 存储 =====
STORAGE_DIR=./storage

# ===== 生成参数 =====
DEFAULT_SHOT_DURATION=5
DEFAULT_FPS=24
DEFAULT_RESOLUTION=768x1344
DEFAULT_OUTPUT_RESOLUTION=1080x1920
CHARACTER_VARIANT_COUNT=4
MVP_SHOT_COUNT=3

# ===== 硬件配置（页面可切换，此为默认）=====
# rtx5060ti_16g | rtx2080ti_22g
HARDWARE_PROFILE_ID=rtx5060ti_16g

# ===== 远程 ComfyUI（可选，不启动本地 comfyui 容器时使用）=====
# 注释掉 compose 中的 comfyui 服务，并改 backend 环境变量：
# COMFYUI_BASE_URL=http://your-remote-gpu-host:8188
