# ===== 应用 =====
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-random-string

# ===== 数据库 =====
DATABASE_URL=sqlite+aiosqlite:///E:/ai/ai-drama-platform/storage/ai_drama.db

# ===== Redis / Celery（V1.1+）=====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ===== Ollama =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ===== ComfyUI =====
COMFYUI_BASE_URL=http://127.0.0.1:8188

# ===== FFmpeg =====
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ===== 存储 =====
STORAGE_ROOT=E:/ai/ai-drama-platform/storage

# ===== 生成参数 =====
DEFAULT_SHOT_DURATION=5
DEFAULT_FPS=24
DEFAULT_RESOLUTION=768x1344
DEFAULT_OUTPUT_RESOLUTION=1080x1920
CHARACTER_VARIANT_COUNT=4
MVP_SHOT_COUNT=3

# ===== 硬件配置（页面可切换，此为默认）=====
# rtx5060ti_16g | rtx2080ti_22g
HARDWARE_PROFILE_ID=rtx5060ti_16g
